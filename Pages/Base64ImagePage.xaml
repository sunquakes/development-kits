<Page x:Class="DevTools.Pages.Base64ImagePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:resources="clr-namespace:DevTools.Resources"
      Title="Base64ImagePage">
    <Grid Margin="20">
        <StackPanel>
            <Button Click="Back_Click" HorizontalAlignment="Left" Margin="0,0,0,8" Width="40" Height="40" ToolTip="{x:Static resources:Strings.Back}">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Background="#4A4A4A" CornerRadius="20" Width="40" Height="40" SnapsToDevicePixels="True">
                            <TextBlock FontFamily="{StaticResource FontAwesomeSolid}" Text="&#xf060;" FontSize="16" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="#FFFFFF" />
                        </Border>
                    </ControlTemplate>
                </Button.Template>
            </Button>
            <TextBlock Text="{x:Static resources:Strings.PageBase64ToImage}" FontSize="18" Margin="0,10" />
            <TextBox x:Name="InputText" Height="100" TextWrapping="Wrap" AcceptsReturn="True" />
            <Button Click="Decode_Click" Margin="0,10" Width="70" Height="32" ToolTip="{x:Static resources:Strings.Decode}">
                <TextBlock FontFamily="{StaticResource FontAwesomeSolid}" Text="&#xf362;" FontSize="16" FontWeight="Bold" Foreground="#FFFFFF" />
            </Button>
            <StackPanel Orientation="Horizontal" Margin="0,8">
                <TextBlock Text="{x:Static resources:Strings.ImageSize}" FontWeight="Bold" />
                <TextBlock x:Name="ImageDimensionsText" Text="-" />
                <TextBlock Text="{x:Static resources:Strings.Size}" FontWeight="Bold" Margin="12,0,0,0" />
                <TextBlock x:Name="ImageSizeText" Text="-" />
            </StackPanel>
            
            <!-- Image with click to zoom and save button -->
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                
                <!-- Image with click event -->
                <Border Grid.Row="0" BorderBrush="#666" BorderThickness="1" CornerRadius="4">
                    <Image x:Name="ResultImage" 
                           Height="300" 
                           Stretch="Uniform"
                           Cursor="Hand"
                           MouseLeftButtonUp="ResultImage_MouseLeftButtonUp"
                           ToolTip="Click to zoom">
                        <Image.Style>
                            <Style TargetType="Image">
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Opacity" Value="0.8"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Image.Style>
                    </Image>
                </Border>
                
                <!-- Action buttons -->
                <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="8">
                    <Button x:Name="SaveButton" 
                            Click="SaveButton_Click" 
                            Width="32" 
                            Height="32" 
                            Margin="4"
                            Visibility="Collapsed"
                            ToolTip="Save image">
                        <TextBlock FontFamily="{StaticResource FontAwesomeSolid}" 
                                   Text="&#xf0c7;" 
                                   FontSize="14" 
                                   FontWeight="Bold" 
                                   Foreground="#FFFFFF" />
                    </Button>
                    <Button x:Name="ZoomButton" 
                            Click="ZoomButton_Click" 
                            Width="32" 
                            Height="32" 
                            Margin="4"
                            Visibility="Collapsed"
                            ToolTip="Zoom image">
                        <TextBlock FontFamily="{StaticResource FontAwesomeSolid}" 
                                   Text="&#xf00e;" 
                                   FontSize="14" 
                                   FontWeight="Bold" 
                                   Foreground="#FFFFFF" />
                    </Button>
                </StackPanel>
            </Grid>
        </StackPanel>
    </Grid>
</Page>
