<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Card-style button for homepage -->
    <Style x:Key="CardButtonStyle" TargetType="Button">
        <Setter Property="Width" Value="180" />
        <Setter Property="Height" Value="120" />
        <Setter Property="Padding" Value="12" />
        <Setter Property="Background" Value="#4A4A4A" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Foreground" Value="#FFFFFF" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="card" Background="{TemplateBinding Background}" CornerRadius="12" Padding="{TemplateBinding Padding}" SnapsToDevicePixels="True">
                        <Border.Resources>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="#FFFFFF" />
                            </Style>
                        </Border.Resources>
                        <Grid>
                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </StackPanel>
                        </Grid>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="card" Property="Background" Value="#5A5A5A" />
                            <Setter TargetName="card" Property="Effect">
                                <Setter.Value>
                                    <DropShadowEffect Color="#66000000" BlurRadius="18" ShadowDepth="4" />
                                </Setter.Value>
                            </Setter>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="card" Property="Background" Value="#6A6A6A" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.5" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>